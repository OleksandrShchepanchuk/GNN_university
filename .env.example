# Copy this file to .env and adjust as needed. The repo never reads .env directly;
# scripts may load it via python-dotenv if added later.

# Compute device: "cpu", "cuda", or "cuda:0"
REDDIT_GNN_DEVICE=cpu

# Optional override for the dataset root. If unset, src/reddit_gnn/config.py's
# Paths dataclass derives everything from the project root.
# REDDIT_GNN_DATA_ROOT=/absolute/path/to/data

# Global random seed used by scripts when not overridden by config
REDDIT_GNN_SEED=42

# Logging level for rich-configured loggers
REDDIT_GNN_LOG_LEVEL=INFO
