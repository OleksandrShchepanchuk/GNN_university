# Data — track structure but never raw/interim/processed contents
data/raw/*
!data/raw/README.md
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Model artifacts
models/checkpoints/*
!models/checkpoints/.gitkeep
models/predictions/*
!models/predictions/.gitkeep

# Reports — figures and tables are tracked so the README renders on GitHub
# without requiring the reader to re-run the pipeline.
!reports/figures/
!reports/tables/

